extends layout

block content
  //- 页面背景图（由 JS 动态切换）
  .question-page-wrapper
    //- 计时器
    #timer.timer-circle 60
    
    .question-content
      #levelBadge.badge LOADING...
      h2#questionText -- Loading Question --
      
      //- 选项区域：Laptop 2x2, Mobile 1x4
      .options-grid
        button.option-btn(onclick="checkAnswer('A')")#optA (Option A)
        button.option-btn(onclick="checkAnswer('B')")#optB (Option B)
        button.option-btn(onclick="checkAnswer('C')")#optC (Option C)
        button.option-btn(onclick="checkAnswer('D')")#optD (Option D)
      
      //- 解释区域（初始隐藏）
      #explanationBox.explanation-container(style="display: none;")
        p.exp-title EXPLANATION
        p#explanationText ...
        button.btn-gold(onclick="finishChallenge()") CONTINUE