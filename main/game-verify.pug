doctype html
html
  head
    title Unlock Secret
    link(rel="stylesheet", href="/css/game-player.css")
  body.verify-page(style="background: #1a1a1a; color: white; text-align: center; padding: 50px 20px;")
    .hero-box
      h2.title UNLOCK CELL
      p.desc Enter the codes found on the map
      
      .input-group(style="margin: 20px 0;")
        input#cellCode.btn-pill(type="text", placeholder="CELL CODE (e.g. C03)", style="width: 80%; background: #333; margin-bottom: 10px; color: gold;")
        input#verifyCode.btn-pill(type="text", placeholder="4-DIGIT VERIFY CODE", style="width: 80%; background: #333; color: gold;")
      
      button#submitVerify.btn-pill(style="background: gold; color: black; font-weight: bold;") SUBMIT
      button.btn-pill(onclick="window.history.back()", style="margin-top: 10px; opacity: 0.7;") BACK

    script.
      document.getElementById('submitVerify').onclick = async () => {
          const res = await fetch('/game/submit-verification', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                  sessionId: "#{room.session_id}", 
                  cellCode: document.getElementById('cellCode').value,
                  verifyCode: document.getElementById('verifyCode').value
              })
          });
          const data = await res.json();
          alert(data.message);
          if (data.success) {
              window.location.href = "/game-start-player/#{room.session_access_code}";
          }
      };